<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.cloud.mapper.AssetItemMapper">

    <insert id="insertAssetItem"
            parameterType="org.cloud.domain.entity.AssetItem"
            useGeneratedKeys="true"
            keyProperty="assetId">
        INSERT INTO asset_item (
            config_id,
            ticker
        )
        VALUES (
            #{configId},
            #{ticker}
        )
    </insert>

    <select id="findByConfigId"
            resultType="org.cloud.domain.entity.AssetItem">
        SELECT
            asset_id AS assetId,
            config_id,
            ticker
        FROM asset_item
        WHERE config_id = #{configId}
    </select>

</mapper>