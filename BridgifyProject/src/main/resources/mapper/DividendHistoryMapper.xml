<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cloud.mapper.DividendHistoryMapper">

    <select id="findDps" resultType="java.math.BigDecimal">
        SELECT dps
        FROM dividend_history
        WHERE ticker = #{ticker}
          AND year = #{year}
    </select>

    <select id="findByTicker" resultType="org.cloud.domain.entity.DividendHistory">
        SELECT *
        FROM dividend_history
        WHERE ticker = #{ticker}
        ORDER BY year
    </select>

</mapper>
